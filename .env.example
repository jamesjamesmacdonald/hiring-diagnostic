# Anthropic API
# Get key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
# From your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# AI Jobs Index API (NTP-owned)
# If you don't have this running yet, leave blank. CLOSE stage falls back to a notice.
AI_JOBS_INDEX_API_URL=https://api.aijobsindex.com.au/v1
AI_JOBS_INDEX_API_KEY=

# Site URL
# Used for PDF generation, og:image tags, and library entry links.
# Local: http://localhost:3000
# Production: https://hiring-diagnostic.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
