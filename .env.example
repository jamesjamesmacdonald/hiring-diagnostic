# Anthropic API
# Get key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
# From your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Salary data API (optional)
# Leave blank. The CLOSE stage salary band comes from a built-in table.
# Set these only if you wire a live salary API later.
SALARY_API_URL=
SALARY_API_KEY=

# Site URL
# Used for PDF generation, og:image tags, and library entry links.
# Local: http://localhost:3000
# Production: https://hiring-diagnostic.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
